# ─── Server Configuration ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ───────────────────────────────────────────────────────────────────
# MongoDB Atlas Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=

# ─── Redis (Optional, for enhanced caching) ────────────────────────────────────
# Redis Labs or self-hosted Redis
REDIS_URL=
# ─── Instagram Session Cookies ──────────────────────────────────────────────────
# REQUIRED for scraping post likes & comments (Instagram blocks bots without them)
# 
# HOW TO GET THEM:
# 1. Open Chrome and log in to instagram.com with your account
# 2. Press F12 → Application/Storage tab → Cookies → https://www.instagram.com
# 3. Find and copy these cookie values:
#    - sessionid (36 char alphanumeric)
#    - csrftoken (32 char alphanumeric)
#    - ds_user_id (10+ digits)
# 4. Paste them below
# 5. Keep these PRIVATE - never share or commit to GitHub!
#
# ⚠️ SECURITY: These cookies expire after ~3 months. Rotate them regularly!
#
IG_SESSIONID=your_session_id_here
IG_CSRFTOKEN=your_csrf_token_here
IG_DS_USER_ID=your_user_id_here

# ─── CORS Configuration ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Examples: http://localhost:3000, https://myapp.com, https://app.myapp.com
CORS_ORIGIN=http://localhost:3000

# ─── API Deployment ────────────────────────────────────────────────────────────
# When deployed to production, use your actual domain
# CORS_ORIGIN=https://yourdomain.com

# ─── Logging ────────────────────────────────────────────────────────────────────
# Set to 'true' for verbose logging
LOG_LEVEL=info
